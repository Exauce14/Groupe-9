# ================================
# DATABASE CONFIGURATION (TEST)
# ================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=base_de_donne_projet_integrateur
DB_USER=postgres
DB_PASSWORD=admin

# ================================
# SERVER CONFIGURATION (TEST)
# ================================
PORT=3001
NODE_ENV=test

# ================================
# JWT CONFIGURATION (TEST)
# ================================
JWT_SECRET=test_secret_key_for_testing_only
JWT_EXPIRATION=24h

# ================================
# BCRYPT CONFIGURATION (TEST)
# ================================
BCRYPT_ROUNDS=10

# ================================
# SECURITY CONFIGURATION (TEST)
# ================================
MAX_LOGIN_ATTEMPTS=3
ACCOUNT_LOCK_DURATION=900000

# ================================
# EMAIL CONFIGURATION (TEST)
# ================================
EMAIL_MODE=dev

# Configuration Gmail (désactivée en mode test)
EMAIL_SERVICE=gmail
EMAIL_USER=test@example.com
EMAIL_PASSWORD=test_password

# ================================
# WEBSOCKET CONFIGURATION (TEST)
# ================================
SOCKET_IO_CORS_ORIGIN=*